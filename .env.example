# Database
POSTGRES_USER=atlas
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=atlas
DATABASE_URL=postgresql://atlas:change-me-to-a-strong-password@postgres:5432/atlas

# API Key (generate with: openssl rand -hex 32)
ATLAS_API_KEY=replace-with-generated-key

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Frontend (optional, defaults to /api)
VITE_API_URL=/api
